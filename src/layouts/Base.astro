---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  active?: 'work' | 'writing' | 'credentials' | 'about' | 'contact' | null;
}

const {
  title = 'Andres Jimenez — Software Engineer',
  description = 'Andres Jimenez builds across the stack — a native bit-perfect iOS audio player, a self-hosted homelab, and computer-vision and algorithm projects.',
  active = null,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
// PNG, not SVG: Slack, iMessage, X, LinkedIn and Facebook all ignore an SVG
// og:image and show no preview at all. public/assets/og.svg stays the editable
// source — re-render it to og.png (1200×630) after any edit. Render locally
// rather than in CI: the card is set in JetBrains Mono and Newsreader, which a
// build runner doesn't have.
const ogImage = new URL('assets/og.png', Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <!-- Dimensions let scrapers lay the large card out before fetching it. -->
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Andres Jimenez — software engineer" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Andres Jimenez — software engineer" />

    <!-- Set theme before paint to avoid a flash of the wrong theme -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('andres_theme');
          if (t !== 'light' && t !== 'dark') {
            t = window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
          }
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Hanken+Grotesk:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header active={active} />
    <main class="page-in"><slot /></main>
    <Footer />

    <!-- Scroll-reveal: add .is-in as elements enter the viewport -->
    <script>
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const els = Array.from(document.querySelectorAll('[data-reveal]'));
      if (reduced || !('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('is-in'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                const el = e.target as HTMLElement;
                const d = parseInt(el.getAttribute('data-reveal-delay') || '0', 10);
                window.setTimeout(() => el.classList.add('is-in'), d);
                io.unobserve(el);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -6% 0px' }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>

    <!-- Hover-to-play card loops. The still behind the video acts as the poster. -->
    <script>
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const vids = Array.from(
          document.querySelectorAll('[data-hover-video]')
        ) as HTMLVideoElement[];

        vids.forEach((v) => {
          const host = (v.closest('a') ?? v.parentElement) as HTMLElement | null;
          if (!host) return;
          let loaded = false;
          let hovering = false;

          const attempt = () => {
            // Rejects with AbortError if the pointer leaves mid-play.
            v.play()
              .then(() => {
                // The pointer may already be gone by the time this resolves.
                if (hovering) v.classList.add('is-playing');
                else v.pause();
              })
              .catch(() => {});
          };

          const play = (e?: PointerEvent) => {
            // Touch fires pointerenter on the tap that navigates away — don't
            // pull down a video we're about to leave.
            if (e && e.pointerType !== 'mouse') return;
            hovering = true;
            if (!loaded) {
              loaded = true;
              // Under preload="none" nothing is fetched until play() asks for
              // it, so assign the source and let play() start the download.
              v.src = v.dataset.src || '';
            }
            attempt();
          };

          const stop = () => {
            hovering = false;
            v.pause();
            v.currentTime = 0;
            v.classList.remove('is-playing');
          };

          host.addEventListener('pointerenter', play);
          host.addEventListener('pointerleave', stop);
          // focus doesn't bubble; focusin does.
          host.addEventListener('focusin', () => play());
          host.addEventListener('focusout', stop);
          v.addEventListener('stop-hover-video', stop);
        });
      }
    </script>
  </body>
</html>
