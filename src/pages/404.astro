---
import Base from '../layouts/Base.astro';
import { url } from '../lib/url';
---

<Base title="404 — Andres Jimenez" description="Page not found.">
  <section class="nf wrap">
    <div class="nf__cmd">$ cd ./{Astro.url.pathname} → no such file or directory</div>
    <h1 class="nf__title">404</h1>
    <p class="nf__lead">This page wandered off. Let's get you back.</p>
    <a class="btn-primary" href={url('/')}>Back home <span class="arrow">→</span></a>
  </section>
</Base>

<style>
  .nf {
    padding: clamp(80px, 14vw, 200px) 0;
    text-align: center;
  }
  .nf__cmd {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-2);
    margin-bottom: 28px;
    word-break: break-word;
  }
  .nf__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(80px, 18vw, 200px);
    line-height: 1;
    letter-spacing: -0.04em;
    margin: 0 0 12px;
    color: var(--ink);
  }
  .nf__lead {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(20px, 3vw, 30px);
    color: var(--ink-2);
    margin: 0 0 36px;
  }
</style>
