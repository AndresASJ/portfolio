---
import Base from '../layouts/Base.astro';
import {
  credentialsSorted,
  kindFilters,
  kindLabel,
} from '../data/credentials';

const items = credentialsSorted();
const isEmpty = items.length === 0;
---

<Base
  active="credentials"
  title="Credentials — Andres Jimenez"
  description="Badges, certifications and events — the milestones alongside the projects."
>
  <section class="wrap-narrow creds-intro">
    <div class="eyebrow">// credentials</div>
    <h1 class="creds-intro__title">Credentials</h1>
    <p class="creds-intro__lead">
      Badges, certifications and events, all in one place — the milestones
      collected alongside the projects.
    </p>
  </section>

  <section class="creds-filterbar">
    <div class="creds-filterbar__row wrap-narrow">
      <div class="chips" data-kind-group>
        {
          kindFilters.map((f) => (
            <button
              class:list={['chip', { 'chip--active': f.key === 'All' }]}
              data-kind={f.key}
              type="button"
            >
              {f.label}
            </button>
          ))
        }
      </div>
      <span class="creds-filterbar__count" data-result-count>
        {items.length} item(s)
      </span>
    </div>
  </section>

  <section class="wrap-narrow creds-list" data-list>
    {
      items.map((c) => {
        const Row = c.url ? 'a' : 'div';
        return (
          <Row
            class="entry"
            href={c.url}
            target={c.url ? '_blank' : undefined}
            rel={c.url ? 'noopener noreferrer' : undefined}
            data-item
            data-kind={c.kind}
            data-reveal
          >
            <span class="entry__date">{c.date}</span>
            <span class="entry__main">
              <span class="entry__meta">
                <span class:list={['entry__tag', `entry__tag--${c.kind}`]}>
                  {kindLabel[c.kind]}
                </span>
                <span class="entry__issuer">{c.issuer}</span>
              </span>
              <span class="entry__title">{c.title}</span>
              <span class="entry__desc">{c.description}</span>
              {c.tags && c.tags.length > 0 && (
                <span class="entry__extras">
                  {c.tags.map((t) => (
                    <span class="tag">{t}</span>
                  ))}
                </span>
              )}
            </span>
            <span class="entry__arrow">{c.url ? '↗' : ''}</span>
          </Row>
        );
      })
    }
    {!isEmpty && <div class="entry__end" />}

    <div class="empty" data-empty hidden={!isEmpty}>
      <div class="empty__cmd">
        {isEmpty ? '$ ls ./credentials → empty' : '$ ls ./credentials → 0 matches'}
      </div>
      <p class="empty__line">
        {isEmpty
          ? 'Badges, certs & events — being collected.'
          : 'Nothing in this category — yet.'}
      </p>
    </div>
  </section>
</Base>

<script>
  const btns = Array.from(
    document.querySelectorAll('[data-kind-group] .chip')
  ) as HTMLElement[];
  const items = Array.from(document.querySelectorAll('[data-item]')) as HTMLElement[];
  const countEl = document.querySelector('[data-result-count]');
  const empty = document.querySelector('[data-empty]') as HTMLElement | null;

  function apply(kind: string) {
    let visible = 0;
    items.forEach((el) => {
      const show = kind === 'All' || el.getAttribute('data-kind') === kind;
      el.hidden = !show;
      if (show) visible++;
    });
    if (countEl) countEl.textContent = `${visible} item(s)`;
    if (empty) empty.hidden = visible !== 0;
  }

  btns.forEach((b) =>
    b.addEventListener('click', () => {
      const kind = b.getAttribute('data-kind') || 'All';
      btns.forEach((x) =>
        x.classList.toggle('chip--active', x.getAttribute('data-kind') === kind)
      );
      apply(kind);
    })
  );
</script>

<style>
  .wrap-narrow {
    max-width: 1100px;
    margin: 0 auto;
    padding-left: clamp(20px, 5vw, 72px);
    padding-right: clamp(20px, 5vw, 72px);
  }
  .creds-intro {
    padding-top: clamp(48px, 7vw, 100px);
    padding-bottom: clamp(28px, 4vw, 48px);
  }
  .creds-intro .eyebrow {
    margin-bottom: 20px;
  }
  .creds-intro__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(44px, 7vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.025em;
    margin: 0 0 20px;
    color: var(--ink);
  }
  .creds-intro__lead {
    font-size: clamp(16px, 1.6vw, 20px);
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 50ch;
    margin: 0;
  }

  /* --- Filter bar --- */
  .creds-filterbar {
    position: sticky;
    top: 71px;
    z-index: 30;
    background: color-mix(in srgb, var(--paper) 90%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 16px 0;
  }
  .creds-filterbar__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 14px 20px;
  }
  .creds-filterbar__count {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-2);
    white-space: nowrap;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .chip {
    background: transparent;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid var(--line);
    color: var(--ink-2);
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .chip:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .chip--active {
    background: var(--accent);
    color: var(--on-accent);
    border-color: var(--accent);
  }
  .chip--active:hover {
    color: var(--on-accent);
  }

  /* --- List --- */
  .creds-list {
    padding-top: clamp(24px, 3vw, 40px);
    padding-bottom: clamp(60px, 8vw, 110px);
  }
  .entry {
    display: grid;
    grid-template-columns: 150px 1fr 90px;
    align-items: baseline;
    gap: clamp(12px, 3vw, 40px);
    width: 100%;
    text-align: left;
    text-decoration: none;
    border-top: 1px solid var(--line);
    padding: clamp(26px, 3vw, 40px) 12px;
    color: var(--ink);
    transition: background 0.2s ease, padding 0.2s ease;
  }
  .entry[hidden] {
    display: none;
  }
  a.entry {
    cursor: pointer;
  }
  a.entry:hover {
    background: var(--accent-soft);
    padding-left: 24px;
  }
  .entry__date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-2);
  }
  .entry__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 8px;
  }
  .entry__tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 3px 8px;
  }
  .entry__issuer {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-2);
  }
  .entry__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(24px, 3vw, 38px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    display: block;
    margin-bottom: 8px;
  }
  .entry__desc {
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink-2);
    display: block;
    max-width: 56ch;
  }
  .entry__extras {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 12px;
  }
  .entry__extras .tag {
    font-size: 11px;
    padding: 4px 9px;
    border-radius: 5px;
  }
  .entry__arrow {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--accent);
    text-align: right;
  }
  .entry__end {
    border-top: 1px solid var(--line);
  }

  /* --- Empty state --- */
  .empty {
    border: 1px dashed var(--line);
    border-radius: 14px;
    padding: clamp(48px, 8vw, 90px) 24px;
    text-align: center;
    margin-top: 24px;
  }
  .empty__cmd {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-2);
    margin-bottom: 16px;
  }
  .empty__line {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(22px, 3vw, 32px);
    color: var(--ink);
    margin: 0;
  }

  @media (max-width: 640px) {
    .entry {
      grid-template-columns: 1fr 40px;
    }
    .entry__date {
      display: none;
    }
  }
</style>
