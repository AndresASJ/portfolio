---
import Base from '../../layouts/Base.astro';
import { url } from '../../lib/url';
import { posts } from '../../data/posts';
import { site } from '../../data/portfolio';

export function getStaticPaths() {
  return posts.map((p) => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const post = posts.find((p) => p.id === id)!;
---

<Base active="writing" title={`${post.title} — Andres Jimenez`} description={post.excerpt}>
  <article class="article">
    <a class="back" href={url('/writing')}>← writing</a>

    <div class="article__meta">
      <span class="article__tag">{post.tag}</span>
      <span>{post.date}</span>
      <span>·</span>
      <span>{post.read} read</span>
    </div>
    <h1 class="article__title">{post.title}</h1>
    <p class="article__lede">{post.excerpt}</p>

    <div class="article__body">
      {
        post.body.map((blk) => {
          if (blk.type === 'h') return <h2 class="article__h">{blk.text}</h2>;
          if (blk.type === 'code')
            return (
              <pre class="article__pre"><code>{blk.text}</code></pre>
            );
          return <p class="article__p">{blk.text}</p>;
        })
      }
    </div>

    <div class="article__author">
      <div class="article__avatar">{site.initials}</div>
      <div>
        <div class="article__author-name">{site.name}</div>
        <div class="article__author-role">
          {site.role}{site.location ? ` · ${site.location.toLowerCase()}` : ''}
        </div>
      </div>
    </div>
  </article>
</Base>

<style>
  .article {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(40px, 6vw, 80px) clamp(20px, 5vw, 40px) clamp(60px, 8vw, 110px);
  }
  .back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-2);
    text-decoration: none;
    margin-bottom: clamp(32px, 5vw, 52px);
    transition: color 0.2s ease;
  }
  .back:hover {
    color: var(--accent);
  }
  .article__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-2);
    margin-bottom: 22px;
  }
  .article__tag {
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .article__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(36px, 5.4vw, 64px);
    line-height: 1.04;
    letter-spacing: -0.025em;
    margin: 0 0 24px;
    color: var(--ink);
  }
  .article__lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(20px, 2.4vw, 27px);
    line-height: 1.4;
    color: var(--ink-2);
    margin: 0 0 clamp(36px, 5vw, 52px);
    padding-bottom: clamp(28px, 4vw, 44px);
    border-bottom: 1px solid var(--line);
  }
  .article__body {
    font-size: clamp(18px, 1.5vw, 20px);
    line-height: 1.72;
    color: var(--ink);
  }
  .article__p {
    margin: 0 0 26px;
  }
  .article__h {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(26px, 3vw, 36px);
    letter-spacing: -0.02em;
    margin: clamp(36px, 5vw, 52px) 0 18px;
    color: var(--ink);
  }
  .article__pre {
    background: var(--card);
    border: 1px solid var(--line);
    border-left: 3px solid var(--accent);
    border-radius: 8px;
    padding: 20px 22px;
    overflow-x: auto;
    margin: 0 0 28px;
  }
  .article__pre code {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.7;
    color: var(--ink);
    white-space: pre;
  }
  .article__author {
    margin-top: clamp(40px, 6vw, 64px);
    padding-top: 28px;
    border-top: 1px solid var(--line);
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .article__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--accent-soft);
    border: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--accent);
  }
  .article__author-name {
    font-size: 15px;
    font-weight: 700;
    color: var(--ink);
  }
  .article__author-role {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-2);
  }
</style>
