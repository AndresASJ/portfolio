---
import Base from '../layouts/Base.astro';
import { socials, site } from '../data/portfolio';
---

<Base
  active="contact"
  title="Contact — Andres Jimenez"
  description="Get in touch with Andres Jimenez — hiring, collaborating, or comparing notes on audio, self-hosting and systems."
>
  <section class="wrap-wide contact">
    <div class="contact__grid">
      <div class="contact__left" data-reveal>
        <div class="eyebrow contact__eyebrow">// contact</div>
        <h1 class="contact__title">Let's talk.</h1>
        <p class="contact__lead">
          Hiring, collaborating, or just want to compare notes on lossless
          audio, self-hosting and systems — I read every message.
        </p>
        <div class="contact__avail">
          <span class="dot" style="width:9px;height:9px;"></span>{site.availability}
        </div>
        <div class="contact__links">
          <a class="contact__link" href={`mailto:${site.email}`}>
            <span class="contact__link-label">{site.email}</span>
            <span class="contact__link-meta">email ↗</span>
          </a>
          {
            socials.map((s) => (
              <a class="contact__link" href={s.href} target="_blank" rel="noopener noreferrer">
                <span class="contact__link-label">{s.label}</span>
                <span class="contact__link-meta">visit ↗</span>
              </a>
            ))
          }
        </div>
      </div>

      <div class="contact__card" data-reveal data-reveal-delay="100">
        <div class="contact__card-head"><span class="contact__card-tilde">~/</span>send-message</div>
        <form class="contact__form" id="contact-form">
          <label class="field">
            <span class="field__label">Name</span>
            <input type="text" name="name" placeholder="Your name" required />
          </label>
          <label class="field">
            <span class="field__label">Email</span>
            <input type="email" name="email" placeholder="you@company.com" required />
          </label>
          <label class="field">
            <span class="field__label">Message</span>
            <textarea name="message" rows="4" placeholder="What's on your mind?" required
            ></textarea>
          </label>
          <button class="btn-primary contact__submit" type="submit">
            Send message <span class="arrow">→</span>
          </button>
          <p class="contact__note" data-form-note hidden></p>
        </form>
      </div>
    </div>
  </section>
</Base>

<script define:vars={{ email: site.email }}>
  const form = document.getElementById('contact-form');
  const note = document.querySelector('[data-form-note]');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = String(data.get('name') || '');
    const from = String(data.get('email') || '');
    const message = String(data.get('message') || '');
    const subject = encodeURIComponent(`Portfolio message from ${name}`);
    const body = encodeURIComponent(`${message}\n\n— ${name}\n${from}`);
    window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
    if (note) {
      note.hidden = false;
      note.textContent = 'Opening your email app… if nothing happens, email me directly.';
    }
  });
</script>

<style>
  .wrap-wide {
    max-width: 1180px;
    margin: 0 auto;
    padding-left: clamp(20px, 5vw, 72px);
    padding-right: clamp(20px, 5vw, 72px);
  }
  .contact {
    padding-top: clamp(48px, 7vw, 110px);
    padding-bottom: clamp(60px, 8vw, 110px);
  }
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 88px);
  }
  .contact__eyebrow {
    letter-spacing: 0.14em;
    margin-bottom: 22px;
  }
  .contact__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(40px, 6vw, 82px);
    line-height: 0.98;
    letter-spacing: -0.025em;
    margin: 0 0 26px;
    color: var(--ink);
  }
  .contact__lead {
    font-size: clamp(17px, 1.8vw, 21px);
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 34ch;
    margin: 0 0 40px;
  }
  .contact__avail {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink);
    margin-bottom: 34px;
  }
  .contact__links {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .contact__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 4px;
    border-top: 1px solid var(--line);
    text-decoration: none;
    color: var(--ink);
    transition: padding 0.2s ease;
  }
  .contact__link:hover {
    padding-left: 14px;
  }
  .contact__link-label {
    font-family: var(--font-serif);
    font-size: clamp(19px, 2vw, 24px);
    word-break: break-word;
  }
  .contact__link-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    white-space: nowrap;
  }

  .contact__card {
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: clamp(26px, 3.5vw, 42px);
    align-self: start;
  }
  .contact__card-head {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-2);
    margin-bottom: 26px;
  }
  .contact__card-tilde {
    color: var(--accent);
  }
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .field {
    display: block;
  }
  .field__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-2);
    display: block;
    margin-bottom: 8px;
  }
  .field input,
  .field textarea {
    width: 100%;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 13px 14px;
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--ink);
  }
  .field textarea {
    resize: vertical;
  }
  .contact__submit {
    width: 100%;
  }
  .contact__note {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-2);
    margin: 4px 0 0;
    text-align: center;
  }

  @media (max-width: 760px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
